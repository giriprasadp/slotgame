# Huff and Puff Backend — Environment Variables
# Copy this to .env and fill in your values

NODE_ENV=development
PORT=3000

# PostgreSQL connection string
# Using existing postgres-db container (postgres:15 on port 5432)
DATABASE_URL=postgres://myuser:pass123@localhost:5432/huffpuff

# Redis connection string
# Using existing my-redis-container (redis:latest on port 6379)
REDIS_URL=redis://localhost:6379

# JWT RS256 — generate keys with: npm run keys:generate
# Paths to PEM files on the server filesystem
JWT_PRIVATE_KEY_PATH=./keys/private.pem
JWT_PUBLIC_KEY_PATH=./keys/public.pem
JWT_EXPIRY=4h

# CORS (comma-separated origins or * for dev)
CORS_ORIGIN=*

# Rate limiting: max requests per window (ms) per session token
RATE_LIMIT_MAX=20
RATE_LIMIT_WINDOW=10000

# Redis Streams keys
ANALYTICS_STREAM_KEY=stream:analytics
ANALYTICS_CONSUMER_GROUP=analytics-workers

# Admin API key (plain string, keep secret)
ADMIN_API_KEY=changeme_admin_key_here
