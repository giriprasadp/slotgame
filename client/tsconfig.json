{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2020", "DOM", "DOM.Iterable"],
    "strict": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": "src",
    "resolveJsonModule": true,
    "allowImportingTsExtensions": false,
    "noEmit": true
  },
  "include": ["src/vite-env.d.ts", "src/main.ts", "src/Game.ts", "src/renderer/Renderer.ts",
               "src/api/ApiClient.ts", "src/config/constants.ts",
               "src/types/api.ts", "src/utils/helpers.ts",
               "src/audio/AudioManager.ts"],
  "exclude": ["node_modules", "dist",
               "src/scenes", "src/game"]
}
